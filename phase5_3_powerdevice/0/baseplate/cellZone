dimensions      [0 0 0 0 0 0 0];

internalField   uniform 4;

boundaryField
{
    baseplate
    {
        type            calculated;
        value           uniform -1;
    }
    baseplate_to_dbc_cu_bot
    {
        type            calculated;
        value           uniform 0;
    }
}


