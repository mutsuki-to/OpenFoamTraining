FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Which steps to run
castellatedMesh true;
snap            true;
addLayers       false;     // Phase 5-1 では境界層省略

// Geometry definitions
geometry
{
    chip.stl
    {
        type    triSurfaceMesh;
        name    chip;
        scale   0.001;    // mm -> m
    }

    dbc_cu_top.stl
    {
        type    triSurfaceMesh;
        name    dbc_cu_top;
        scale   0.001;
    }

    dbc_ceramic.stl
    {
        type    triSurfaceMesh;
        name    dbc_ceramic;
        scale   0.001;
    }

    dbc_cu_bot.stl
    {
        type    triSurfaceMesh;
        name    dbc_cu_bot;
        scale   0.001;
    }

    baseplate.stl
    {
        type    triSurfaceMesh;
        name    baseplate;
        scale   0.001;
    }

    // 部品周辺だけメッシュを細かくするための仮想ボックス

}

// castellatedMesh phase settings
castellatedMeshControls
{
    maxLocalCells       100000;
    maxGlobalCells      2000000;
    minRefinementCells  10;
    maxLoadUnbalance    0.10;
    nCellsBetweenLevels 5;

    // 稜線情報の利用
    features
    (
       
    );

    // 表面ごとの細分化レベル
    refinementSurfaces
    {
        chip
        {
            level    (3 4);     // (min max)
        }
        dbc_cu_top
        {
            level    (3 4);
        }
        dbc_ceramic
        {
            level    (2 3);
        }
        dbc_cu_bot
        {
            level    (3 4);
        }
        baseplate
        {
            level    (2 3);
        }
    }

    resolveFeatureAngle 30;

    // 領域ベースの細分化
    refinementRegions
    {
    }

    // 残す側を指定 (空気領域内の点、部品から離れた場所)
    locationsInMesh
    (
    ( (0.001 0.001  0.00045) chip)   // chip内部
    ((0.001 0.001  0.00015) dbc_cu_top)   // dbc_cu_top内部
    ((0.001 0.001 -0.00032) dbc_ceramic)   // dbc_ceramic内部
    ((0.001 0.001 -0.00079) dbc_cu_bot)   // dbc_cu_bot内部
    ((0.001 0.001 -0.00244) baseplate)   // baseplate内部        
    );

    allowFreeStandingZoneFaces true;
}  

// Snap phase settings
snapControls
{
    nSmoothPatch        3;
    tolerance           2.0;
    nSolveIter          30;
    nRelaxIter          5;
    nFeatureSnapIter    10;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

// AddLayers phase settings (今回は使わない)
addLayersControls
{
    relativeSizes       true;
    layers              {}
    expansionRatio      1.0;
    finalLayerThickness 0.3;
    minThickness        0.1;
    nGrow               0;
    featureAngle        60;
    nRelaxIter          5;
    nSmoothSurfaceNormals 1;
    nSmoothNormals      3;
    nSmoothThickness    10;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedialAxisAngle  90;
    nBufferCellsNoExtrude 0;
    nLayerIter          50;
}

// Mesh quality settings
meshQualityControls
{
    maxNonOrtho             65;
    maxBoundarySkewness     20;
    maxInternalSkewness     4.5;
    maxConcave              80;
    minVol                  1e-13;
    minTetQuality           1e-15;
    minArea                 -1;
    minTwist                0.02;
    minDeterminant          0.001;
    minFaceWeight           0.02;
    minVolRatio             0.01;
    minTriangleTwist        -1;
    nSmoothScale            4;
    errorReduction          0.75;
}

writeFlags
(
    scalarLevels
    layerSets
    layerFields
);

mergeTolerance 1e-6;

// ************************************************************************* //
