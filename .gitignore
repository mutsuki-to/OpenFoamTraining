# OpenFOAM log files (can be hundreds of MB)
log.*
log_*

# Parallel decomposition data
processor*/

# Visualization output
VTK/
*.vtu
*.vtk
*.foam

# Post-processing results
postProcessing/

# Temporary and system files
*.orig.bak
*~
*.Zone.Identifier
*:Zone.Identifier

# Large mesh files (regenerable via blockMesh/snappyHexMesh/checkMesh)
# マルチリージョン構成では constant/<region>/polyMesh/ になるため、
# 直下(シングルリージョン)とワイルドカードの両方を拾う。
phase5_4*/constant/polyMesh/
phase5_4*/constant/*/polyMesh/
phase5_3_test/constant/polyMesh/
phase5_3_test/constant/*/polyMesh/

# ParaView state files
*.pvsm
