dimensions      [ 0 0 0 1 0 0 0 ];

internalField   uniform 300;

boundaryField
{
    ".*"
    {
        type            zeroGradient;
    }
    dbc_cu_top
    {
        type            zeroGradient;
    }
    dbc_cu_top_to_chip
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        value           uniform 300;
        Tnbr            T;
        kappaMethod     solidThermo;
    }
    dbc_cu_top_to_dbc_ceramic
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        value           uniform 300;
        Tnbr            T;
        kappaMethod     solidThermo;
    }
}


