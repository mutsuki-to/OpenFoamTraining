FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system/chip";
    object      fvOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

heatSource
{
    type            scalarSemiImplicitSource;

    selectionMode   all;
    volumeMode      absolute;

    sources
    {
        h
        {
            explicit    0.5;     // 発熱量 [W]
            implicit    0;
        }
    }
}

