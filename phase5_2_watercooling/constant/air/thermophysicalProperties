FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant/air";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight   28.96;          // 空気の見かけ分子量
    }

    transport
    {
        mu          1.831e-05;      // 動粘度 Pa·s
        Pr          0.705;          // プラントル数
    }

    thermodynamics
    {
        Cp          1004.4;         // 比熱 J/(kg·K)
        Hf          0;
    }
}

