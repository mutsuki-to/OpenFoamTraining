FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       polyBoundaryMesh;
    location    "constant/substrate/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

3
(
    substrate_to_chip
    {
        type            mappedWall;
        inGroups        2(wall mappedPatch);
        nFaces          256;
        startFace       21696;
        sampleMode      nearestPatchFace;
        sampleRegion    chip;
        samplePatch     chip_to_substrate;
    }
    substrate_to_air
    {
        type            mappedWall;
        inGroups        2(wall mappedPatch);
        nFaces          3220;
        startFace       21952;
        sampleMode      nearestPatchFace;
        sampleRegion    air;
        samplePatch     air_to_substrate;
    }
    substrate_bottom
    {
        type            wall;
        inGroups        1(wall);
        nFaces          2116;
        startFace       25172;
    }
)

