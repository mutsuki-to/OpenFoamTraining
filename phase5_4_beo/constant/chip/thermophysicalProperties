FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant/chip";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIso;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight   28.09;          // Si分子量
    }

    transport
    {
        kappa       148;            // 熱伝導率 W/(m·K)
    }

    thermodynamics
    {
        Hf          0;
        Cp          712;            // 比熱 J/(kg·K)
    }

    equationOfState
    {
        rho         2330;           // 密度 kg/m³
    }
}

