FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/heater";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    minY
    {
        type            calculated;
        value           uniform 0.01;
    }
    minZ
    {
        type            calculated;
        value           uniform 0.01;
    }
    maxZ
    {
        type            calculated;
        value           uniform 0.01;
    }
    heater_to_topAir
    {
        type            calculated;
        value           uniform 0;
    }
    heater_to_rightSolid
    {
        type            calculated;
        value           uniform 0;
    }
    heater_to_leftSolid
    {
        type            calculated;
        value           uniform 0;
    }
    heater_to_bottomWater
    {
        type            calculated;
        value           uniform 0;
    }
}


